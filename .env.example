# ============================================
# FTA - Face Time Attendance System
# Environment Configuration
# ============================================

# --- Application ---
APP_NAME=FTA - Face Time Attendance
APP_VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000

# --- Database ---
# PostgreSQL: postgresql://user:password@host:port/dbname
# SQLite: sqlite:///./data/fta.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fta_db
DB_ECHO=false

# --- JWT Authentication ---
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- Camera ---
# USB camera index (0, 1, 2...) or RTSP URL
CAMERA_SOURCE=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# --- Face Recognition ---
# InsightFace model name (buffalo_l, buffalo_s, buffalo_sc)
FACE_MODEL_NAME=buffalo_l
# ONNX provider: cuda, cpu, or auto
FACE_ONNX_PROVIDER=cuda
# Detection confidence threshold (0.0 - 1.0)
FACE_DETECTION_THRESHOLD=0.5
# Recognition distance threshold (lower = stricter matching)
FACE_RECOGNITION_THRESHOLD=0.4
# Minimum face quality score for registration
FACE_MIN_QUALITY=0.3
# Number of face images required for registration
FACE_REGISTRATION_COUNT=3

# --- Anti-Spoofing ---
ANTI_SPOOFING_ENABLED=true
ANTI_SPOOFING_THRESHOLD=0.5
ANTI_SPOOFING_INTERVAL_FRAMES=5

# --- Attendance ---
# Cooldown in seconds before same person can check-in/out again
ATTENDANCE_COOLDOWN_SECONDS=1800
# Work schedule
WORK_START_TIME=08:00
WORK_END_TIME=17:00
LATE_THRESHOLD_MINUTES=15

# --- File Storage ---
FACE_IMAGES_DIR=./data/face_images
FAISS_INDEX_DIR=./data/faiss_index
MODELS_DIR=./data/models
ATTENDANCE_SNAPSHOTS_DIR=./data/snapshots

# --- Logging ---
LOG_LEVEL=INFO
